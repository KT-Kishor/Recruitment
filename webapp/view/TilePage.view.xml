<mvc:View
    controllerName="kt.ai.sap.com.recruitment.controller.TilePage"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:ux="sap.uxap"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
>
    <App>
        <Page
            id="idPageTile"
            class="service-background"
            showHeader="true"
            enableScrolling="false"
        >
            <headerContent>
                <Text
                    text="{= 'Welcome ' + ${LoginModel>/EmployeeName} }"
                    class="boldBlueText sapUiLargeMarginBegin"
                />
                <ToolbarSpacer />
                <!-- <Button press="Tile_NotifictionBTN" icon="sap-icon://bell" visible="{= ${LoginModel>/Role} !== 'Contractor' }"/> -->
                <Button press="Tile_NotifictionBTN" class="sapUiTinyMarginBeginEnd" icon="sap-icon://bell" type="Transparent" visible="{= ${LoginModel>/Role} !== 'Contractor' }" tooltip="{i18n>TilenotificationfragName}">
                    <customData>
                        <BadgeCustomData class="badgeClass" key="badge" value="{EndingSoonModel>/notificationCount}"/>
                    </customData>
                </Button>

                <Button press="TileV_onBackPress" icon="sap-icon://log"/>
            </headerContent>
            <l:ResponsiveSplitter height="100%">
                <l:PaneContainer orientation="Horizontal">
                    <l:SplitPane
                        requiredParentWidth="300"
                        id="default"
                        demandPane="true"
                    >
                        <l:layoutData>
                            <l:SplitterLayoutData size="100%" />
                        </l:layoutData>
                        <ux:ObjectPageLayout
                            upperCaseAnchorBar="false"
                            id="id_ObjectPageLayoutTile"
                        >
                            <ux:sections>
                                <ux:ObjectPageSection
                                    titleUppercase="false"
                                    title="{i18n>recruitment}"
                                    class="roomHeaderTitle1"
                                    visible="{= ${TileAccessModel>/Recruitment} === '1' ? true : false}"
                                >
                                    <ux:subSections>
                                        <ux:ObjectPageSubSection titleUppercase="false">
                                            <ux:blocks>
                                                <layout:HorizontalLayout allowWrapping="true" class="sapUiTinyMargin">

                                                    <GenericTile visible="{= ${AppVisibilityModel>/GenerateEmployeeOffer} === '1' ? true : false}" class="sapUiMediumMargin glassTile blue" header="{i18n>headerEmployeeOffer}" press="TileV_onPressOffer" subheader="{i18n>subhead}">
                                                        <TileContent unit="{i18n>tileUnit}" >
                                                            <ImageContent src="sap-icon://employee-approvals"/>
                                                        </TileContent>
                                                    </GenericTile>

                                                    <GenericTile visible="{= ${AppVisibilityModel>/RecruitmentApp} === '1' ? true : false}" class="sapUiMediumMargin glassTile blue" header="{i18n>TableHeader}" press="TileV_RecruitementDashbord">
                                                        <TileContent unit="{i18n>assetFooter}">
                                                            <ImageContent src="sap-icon://add-employee"/>
                                                        </TileContent>
                                                    </GenericTile>
                                                    <GenericTile visible="{= ${AppVisibilityModel>/JobPosting} === '1' ? true : false}" class="sapUiMediumMargin glassTile blue" header="{i18n>JobPosting}" press="TileV_JobPosting">
                                                        <TileContent unit="{i18n>careers}">
                                                            <ImageContent src="sap-icon://visits"/>
                                                        </TileContent>
                                                    </GenericTile>
                                                </layout:HorizontalLayout>
                                            </ux:blocks>
                                        </ux:ObjectPageSubSection>
                                    </ux:subSections>
                                </ux:ObjectPageSection>
                            </ux:sections>
                        </ux:ObjectPageLayout>
                    </l:SplitPane>
                </l:PaneContainer>
            </l:ResponsiveSplitter>
            <footer>
                <Bar>
                    <contentLeft>
                        <core:Fragment
                            fragmentName="kt.ai.sap.com.recruitment.fragment.Footer"
                            type="XML"
                        />
                    </contentLeft>
                </Bar>
            </footer>
        </Page>
    </App>
</mvc:View>